{
  "name": "multiyou",
  "version": "0.1.0",
  "description": "MultiYou — Pixel Avatar AI Companion",
  "main": "../electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "vue": "^3.4.27",
    "vue-cropper": "next",
    "vue-router": "^4.3.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.5",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.multiyou.app",
    "productName": "MultiYou",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "../electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../python-backend/",
        "to": "python-backend/",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../../assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
